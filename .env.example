# GEMINI_API_KEY: Required for real Gemini AI responses (optional for demo mode).
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# GEMINI_MODEL: AI model used for interview suggestions (default: gemini-2.5-flash).
GEMINI_MODEL="gemini-2.5-flash"

# APP_URL: Public URL where the relay server is hosted (restricts CORS in production).
APP_URL="http://localhost:3000"

# PORT: HTTP port for the relay server (Cloud Run/Railway/Render set this automatically).
PORT=3000

# NODE_ENV: Set to "production" for deployed environments.
NODE_ENV=development

# ADMIN_API_KEY: Protects admin APIs (sessions, rooms list, webhook logs) in production.
# Pass as header: X-Admin-Key: your_secret_here
ADMIN_API_KEY="MY_ADMIN_API_KEY"

# STRIPE_SECRET_KEY: Optional. Enables real Stripe checkout instead of simulation.
STRIPE_SECRET_KEY="MY_STRIPE_SECRET_KEY"

# STRIPE_WEBHOOK_SECRET: Required in production for verified Stripe webhook events.
STRIPE_WEBHOOK_SECRET="MY_STRIPE_WEBHOOK_SECRET"
